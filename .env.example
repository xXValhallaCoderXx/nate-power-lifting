# Neon serverless Postgres connection string
# Get this from https://console.neon.tech (use the pooled connection string)
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Single-athlete login password (plain text; compared server-side)
APP_PASSWORD="change-me"

# Secret used to sign the session cookie. Must be at least 32 characters.
# Generate one with: openssl rand -base64 32
SESSION_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
